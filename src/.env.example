# GitHub OAuth App
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/github/callback

# Database (Postgres + pgvector)
DATABASE_URL=postgresql://repobrain:repobrain@localhost:5432/repobrain

# Redis
REDIS_URL=redis://localhost:6379

# LLM Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Default LLM provider (openai | anthropic | ollama)
DEFAULT_LLM_PROVIDER=openai

# OpenAI OAuth (optional — enables per-user OpenAI auth instead of server API key)
OPENAI_CLIENT_ID=
OPENAI_REDIRECT_URI=http://localhost:3000/api/auth/openai/callback

# Session
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-32-char-string-or-longer

# Blob storage path for cloned repositories
BLOB_STORAGE_PATH=./repos

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
