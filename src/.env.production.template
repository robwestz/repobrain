# =============================================================================
# RepoBrain — Production Environment Template
# =============================================================================
# Copy this file to .env.production (never commit the real .env.production)
# All variables marked REQUIRED must be set or the app will refuse to start.
# =============================================================================

# -----------------------------------------------------------------------------
# GitHub OAuth App  (REQUIRED)
# Create at: https://github.com/settings/developers → OAuth Apps → New
# Callback URL must be: https://your-domain.com/api/auth/github/callback
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_REDIRECT_URI=https://your-domain.com/api/auth/github/callback

# -----------------------------------------------------------------------------
# Database — PostgreSQL with pgvector  (REQUIRED)
# Must NOT be a localhost address in production.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://repobrain_user:STRONG_PASSWORD@db-host:5432/repobrain_prod

# -----------------------------------------------------------------------------
# Redis  (REQUIRED)
# Used for BullMQ job queues and caching.
# Must NOT be a localhost address in production.
# -----------------------------------------------------------------------------
REDIS_URL=redis://:STRONG_PASSWORD@redis-host:6379

# -----------------------------------------------------------------------------
# LLM Providers
# OPENAI_API_KEY is REQUIRED (default provider).
# ANTHROPIC_API_KEY is optional unless DEFAULT_LLM_PROVIDER=anthropic.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...your_openai_key_here
# ANTHROPIC_API_KEY=sk-ant-...your_anthropic_key_here
DEFAULT_LLM_PROVIDER=openai

# -----------------------------------------------------------------------------
# Session Secret  (REQUIRED — minimum 32 characters)
# Generate with: openssl rand -hex 32
# Changing this invalidates all active sessions.
# -----------------------------------------------------------------------------
SESSION_SECRET=replace_with_64_hex_chars_from_openssl_rand_hex_32

# -----------------------------------------------------------------------------
# Blob Storage — path where cloned repos are stored on disk  (REQUIRED)
# Use an absolute path in production.
# Ensure this directory has adequate disk space and is NOT publicly accessible.
# -----------------------------------------------------------------------------
BLOB_STORAGE_PATH=/var/data/repobrain/repos

# -----------------------------------------------------------------------------
# App URL  (REQUIRED)
# The canonical public URL of the deployment (no trailing slash).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://your-domain.com

# -----------------------------------------------------------------------------
# Node environment — must be "production" in production deployments
# -----------------------------------------------------------------------------
NODE_ENV=production
